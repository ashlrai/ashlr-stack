{
  "name": "@ashlr/stack-site",
  "version": "0.1.0",
  "private": true,
  "description": "Marketing site for Ashlr Stack — stack.ashlr.ai",
  "type": "module",
  "scripts": {
    "dev": "bun run sync-content && astro dev",
    "start": "bun run sync-content && astro dev",
    "build": "bun run sync-content && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check && tsc --noEmit",
    "sync-content": "mkdir -p src/data && cp -f ../../CHANGELOG.md src/data/CHANGELOG.md 2>/dev/null || true"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/react": "^4.2.0",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.0.0",
    "@vercel/analytics": "^2.0.1",
    "astro": "^5.1.0",
    "framer-motion": "^11.15.0",
    "marked": "^18.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-icons": "^13.21.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "typescript": "^6.0.3"
  }
}
