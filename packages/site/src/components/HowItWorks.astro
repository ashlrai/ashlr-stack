---
import HowItWorksTabs from "./HowItWorksTabs";
---

<section id="how-it-works" class="relative mx-auto max-w-[1240px] px-6 sm:px-10 pt-14 sm:pt-16 pb-24 sm:pb-28">
  <div class="section-rule mb-10">
    <span>§ 05 · Mechanics</span>
  </div>

  <header class="max-w-[760px] mb-12" data-reveal>
    <h2 class="display text-[color:var(--color-ink-50)]" style="font-size: clamp(32px, 4.4vw, 56px);">
      Three surfaces, <span class="display-accent">one source of truth.</span>
    </h2>
    <p class="mt-5 text-[15px] leading-[1.6] text-[color:var(--color-ink-300)] max-w-[620px]">
      Stack coordinates the <span class="text-[color:var(--color-ink-100)]">CLI</span>, the
      <span class="text-[color:var(--color-ink-100)]">vault</span>, and your
      <span class="text-[color:var(--color-ink-100)]">project files</span> so every developer
      on a repo — and every agent with access — sees an identical stack. Click a step to
      pause the auto-walkthrough.
    </p>
  </header>

  <div data-reveal>
    <HowItWorksTabs client:visible />
  </div>
</section>
