---
import Nav from "./Nav.astro";
import StackOrbit from "./StackOrbit";
import HeroIntroOverlay from "./HeroIntroOverlay";
import GenerateStackDemo from "./GenerateStackDemo";
import { PROVIDERS } from "~/lib/providers";
import { PROVIDERS_REF } from "~/lib/providers-ref";
import { getIconPath } from "~/lib/icons";

const iconPaths: Record<string, string | null> = Object.fromEntries(
  PROVIDERS.map((p) => [p.slug, getIconPath(p.slug)]),
);

// Build the orbit payload from the canonical catalog (29 entries). Join against
// the display catalog for brand color + icon slug — catalog.ts doesn't carry
// either and we want every logo in its real brand color.
const orbitProviders = PROVIDERS_REF.map((p) => {
  const d = PROVIDERS.find((q) => q.name === p.displayName) ??
    PROVIDERS.find((q) => q.slug === p.name);
  return {
    slug: d?.slug ?? p.name,
    name: p.name,
    displayName: p.displayName,
    color: d?.color ?? "e96b2a",
    category: p.category,
  };
});
const orbitIconPaths: Record<string, string | null> = Object.fromEntries(
  orbitProviders.map((p) => [p.slug, getIconPath(p.slug)]),
);
---

<section id="hero" class="relative overflow-hidden">
  <!-- CAD-paper hairline grid (pixel-aligned, no mask) -->
  <div class="absolute inset-0 cad-grid pointer-events-none" aria-hidden="true"></div>

  <Nav />

  <div class="relative mx-auto max-w-[1240px] px-6 sm:px-10 pt-16 sm:pt-20 lg:pt-24 pb-16 lg:pb-20">

    <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_1fr] gap-10 lg:gap-16 items-start">

      <!-- LEFT — copy + demo. Simplified: one eyebrow, headline, one-line subhead,
           the demo (primary CTA), and a small install + source line. No
           stat strip (moved below the logo marquee), no duplicate copy-paste
           prompt (the demo IS the prompt surface). -->
      <div class="relative">
        <!-- tiny technical eyebrow -->
        <div class="eyebrow flex items-center gap-3 mb-7 load-in" style="--load-delay: 40ms">
          <span>STACK</span>
          <span class="text-[color:var(--color-ink-600)]">/</span>
          <span>CONTROL PLANE</span>
          <span class="text-[color:var(--color-ink-600)]">/</span>
          <span>v0.1.1</span>
          <span class="ml-2 inline-flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 bg-[color:var(--color-blade-500)]" style="animation: pulse 1800ms ease-in-out infinite;"></span>
            <span class="text-[color:var(--color-blade-400)]">LIVE ON NPM</span>
          </span>
        </div>

        <div class="eyebrow mb-4 load-in" style="--load-delay: 100ms; color: var(--color-blade-400);">
          the only line you tell claude code
        </div>

        <h1
          class="display text-[color:var(--color-ink-50)]"
          style="font-size: clamp(42px, 5.6vw, 78px);"
        >
          <span class="block load-in" style="--load-delay: 160ms">
            <span class="display-accent">&ldquo;</span>Stack my
          </span>
          <span class="block load-in" style="--load-delay: 240ms">
            backend.<span class="display-accent">&rdquo;</span>
          </span>
        </h1>

        <!-- Single crisp line — no 5-line paragraph of digging. -->
        <p
          class="mt-6 text-[17px] leading-[1.5] text-[color:var(--color-ink-200)] load-in max-w-[560px]"
          style="--load-delay: 320ms"
        >
          One prompt. <strong class="text-[color:var(--color-ink-50)] font-semibold">{PROVIDERS_REF.length} providers</strong>, real accounts, every key vaulted, <span class="mono text-[color:var(--color-ink-100)]">.env</span> + <span class="mono text-[color:var(--color-ink-100)]">.mcp.json</span> wired. In under a minute.
        </p>

        <!-- THE DEMO — primary CTA. Click to watch a real recipe materialize. -->
        <div class="mt-8 max-w-[620px] load-in" style="--load-delay: 420ms">
          <GenerateStackDemo iconPaths={iconPaths} client:visible />
        </div>

        <!-- Install + source, small and unobtrusive. -->
        <div
          class="mt-4 flex flex-wrap items-center gap-3 max-w-[620px] load-in"
          style="--load-delay: 540ms"
        >
          <div class="flex-1 min-w-0 mono text-[11px] text-[color:var(--color-ink-400)] truncate">
            <span class="text-[color:var(--color-ink-500)]">install</span>
            <span class="text-[color:var(--color-ink-600)]">›</span>
            <span class="text-[color:var(--color-ink-200)]">curl -fsSL stack.ashlr.ai/install.sh | bash</span>
          </div>
          <button
            class="copy-btn px-2 py-1 border border-[color:var(--color-ink-700)] text-[10px] tracking-[0.12em] uppercase text-[color:var(--color-ink-400)] hover:border-[color:var(--color-steel-500)] hover:text-[color:var(--color-ink-200)] transition-colors"
            data-copy="curl -fsSL stack.ashlr.ai/install.sh | bash"
            aria-label="Copy install command"
          >
            <span class="copy-label">Copy</span>
          </button>
          <a
            href="https://github.com/ashlrai/ashlr-stack"
            class="mono text-[11px] tracking-[0.12em] uppercase text-[color:var(--color-ink-400)] hover:text-[color:var(--color-ink-100)] transition-colors flex items-center gap-1.5"
            rel="noopener"
            target="_blank"
            aria-label="View source on GitHub"
          >
            <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 .5A11.5 11.5 0 0 0 .5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56 0-.28-.01-1.02-.02-2.01-3.2.7-3.87-1.54-3.87-1.54-.52-1.33-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.2 1.77 1.2 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.56-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.44-2.29 1.17-3.1-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.15 1.18a10.9 10.9 0 0 1 5.74 0c2.19-1.49 3.15-1.18 3.15-1.18.62 1.58.23 2.75.11 3.04.73.81 1.17 1.84 1.17 3.1 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.07.78 2.16 0 1.56-.01 2.82-.01 3.2 0 .31.2.68.8.56A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5z"/>
            </svg>
            Source
          </a>
        </div>
      </div>

      <!-- RIGHT — orbital provider constellation -->
      <div class="relative load-in" style="--load-delay: 300ms">
        <!-- FIG label above -->
        <div class="eyebrow flex items-center justify-between mb-3 text-[color:var(--color-steel-300)]">
          <span>FIG. 01 — PROVIDER CONSTELLATION</span>
          <span>{PROVIDERS_REF.length} PROVIDERS</span>
        </div>

        <!-- Orbital canvas with tick-corner frame -->
        <div class="tick-corners relative panel-steel aspect-square w-full overflow-hidden">
          <span class="tick-tr"></span>
          <span class="tick-bl"></span>

          <!-- All 39 providers orbit the Stack core with periodic
               "stack apply" pulse waves. Pure SVG + CSS, no R3F. -->
          <div class="absolute inset-0">
            <StackOrbit providers={orbitProviders} iconPaths={orbitIconPaths} client:visible />
          </div>

          <!-- Cinematic intro overlay — plays once per session -->
          <HeroIntroOverlay client:idle />
        </div>

        <!-- caption below -->
        <div class="mt-3 flex items-center justify-between text-[color:var(--color-steel-300)] mono text-[11px]">
          <span>3 orbits · headline → core → long-tail</span>
          <span class="text-[color:var(--color-blade-400)]">hover any logo</span>
        </div>
      </div>
    </div>
  </div>

  <script>
    const buttons = document.querySelectorAll<HTMLButtonElement>(".copy-btn");
    buttons.forEach((btn) => {
      btn.addEventListener("click", async () => {
        const text = btn.getAttribute("data-copy") ?? "";
        try {
          await navigator.clipboard.writeText(text);
          const label = btn.querySelector(".copy-label");
          if (label) {
            const original = label.textContent;
            label.textContent = "Copied";
            btn.classList.add("text-[color:var(--color-blade-400)]");
            setTimeout(() => {
              label.textContent = original;
              btn.classList.remove("text-[color:var(--color-blade-400)]");
            }, 1400);
          }
        } catch {
          /* noop */
        }
      });
    });
  </script>
</section>
