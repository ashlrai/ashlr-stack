---
import Logo from "./Logo.astro";
---

<nav class="relative z-30" style="border-bottom: 1px solid var(--color-ink-600);">
  <div class="mx-auto max-w-[1240px] px-6 sm:px-10 h-12 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3">
      <Logo variant="chip" size={22} idSuffix="-nav" />
      <span class="caption text-[color:var(--color-steel-300)] hidden sm:inline">
        control plane · v0.1
      </span>
    </a>

    <div class="flex items-center gap-6 text-[11px] tracking-[0.16em] uppercase" style="font-family: var(--font-mono);">
      <a href="/docs" class="text-[color:var(--color-ink-300)] hover:text-[color:var(--color-ink-50)] transition-colors">Docs</a>
      <a href="/docs/providers" class="text-[color:var(--color-ink-300)] hover:text-[color:var(--color-ink-50)] transition-colors">Providers</a>
      <a href="/docs/mcp" class="text-[color:var(--color-ink-300)] hover:text-[color:var(--color-ink-50)] transition-colors hidden md:inline">MCP</a>
      <a href="/docs/changelog" class="text-[color:var(--color-ink-300)] hover:text-[color:var(--color-ink-50)] transition-colors hidden md:inline">Changelog</a>
      <a
        href="https://github.com/ashlrai/ashlr-stack"
        class="text-[color:var(--color-ink-300)] hover:text-[color:var(--color-blade-400)] transition-colors"
        target="_blank"
        rel="noopener"
      >GitHub</a>
    </div>
  </div>
</nav>
