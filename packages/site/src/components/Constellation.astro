---
interface Node {
  id: string;
  title: string;
  tag: string;
  body: string;
  glyph: string;
  glyphColor: string;
  cx: number;
  cy: number;
  size: "center" | "satellite";
  url?: string;
  link: string; // label for the hover relationship
}

const nodes: Node[] = [
  {
    id: "stack",
    title: "Stack",
    tag: "Control plane",
    body: "The CLI + MCP that provisions, wires, and operates every service.",
    glyph: "▲",
    glyphColor: "var(--color-blade-400)",
    cx: 50,
    cy: 50,
    size: "center",
    link: "you are here",
  },
  {
    id: "phantom",
    title: "Phantom Secrets",
    tag: "Vault",
    body: "E2E-encrypted secret storage. Stack writes every credential through Phantom.",
    glyph: "◇",
    glyphColor: "var(--color-steel-100)",
    cx: 16,
    cy: 28,
    size: "satellite",
    url: "https://phantom.ashlr.ai",
    link: "writes secrets through",
  },
  {
    id: "plugin",
    title: "ashlr-plugin",
    tag: "Context compressor",
    body: "Drops Claude Code token spend ~80% on large repos with genome-indexed read/grep.",
    glyph: "◈",
    glyphColor: "var(--color-blade-300)",
    cx: 84,
    cy: 28,
    size: "satellite",
    url: "https://github.com/ashlrai/ashlr-plugin",
    link: "shares .stack.toml with",
  },
  {
    id: "ashlrcode",
    title: "ashlrcode",
    tag: "Multi-model CLI",
    body: "Route the same prompt across Claude, GPT, Grok, DeepSeek. Compare, diff, stream.",
    glyph: "◎",
    glyphColor: "var(--color-signal-ok,#6fe8a7)",
    cx: 50,
    cy: 88,
    size: "satellite",
    url: "https://github.com/ashlrai/ashlrcode",
    link: "resolves slots via",
  },
];
---

<section id="constellation" class="relative mx-auto max-w-[1240px] px-6 sm:px-10 pt-14 sm:pt-16 pb-24 sm:pb-28">
  <div class="section-rule mb-10">
    <span>§ 09 · The Ashlr constellation</span>
  </div>

  <header class="max-w-[760px] mb-14" data-reveal>
    <h2 class="display text-[color:var(--color-ink-50)]" style="font-size: clamp(32px, 4.4vw, 56px);">
      Four tools. <span class="display-accent">One coherent platform.</span>
    </h2>
    <p class="mt-5 text-[15px] leading-[1.6] text-[color:var(--color-ink-300)] max-w-[620px]">
      Stack is the control plane. Phantom is the vault. ashlr-plugin is the context compressor.
      ashlrcode is the multi-model runtime. They compose — none of them require the others, but
      together they're load-bearing. Hover a satellite to highlight the relationship.
    </p>
  </header>

  <div class="constellation-wrap relative panel-steel p-4 sm:p-10 overflow-hidden" data-reveal>
    <div class="absolute inset-0 cad-grid opacity-60 pointer-events-none" aria-hidden="true"></div>

    <svg
      viewBox="0 0 100 100"
      preserveAspectRatio="none"
      class="absolute inset-0 w-full h-full pointer-events-none"
      aria-hidden="true"
    >
      <defs>
        <linearGradient id="line-grad" x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#e96b2a" stop-opacity="0" />
          <stop offset="50%" stop-color="#e96b2a" stop-opacity="0.55" />
          <stop offset="100%" stop-color="#e96b2a" stop-opacity="0" />
        </linearGradient>
      </defs>
      {nodes.filter((n) => n.id !== "stack").map((n) => (
        <line
          class={`draw-on-view constellation-line constellation-line-${n.id}`}
          x1="50" y1="50"
          x2={n.cx} y2={n.cy}
          stroke="url(#line-grad)"
          stroke-width="0.18"
          vector-effect="non-scaling-stroke"
        />
      ))}
    </svg>

    <!-- Phantom halo behind the central node -->
    <div
      aria-hidden="true"
      class="absolute pointer-events-none"
      style="left:50%;top:50%;width:320px;height:320px;transform:translate(-50%,-50%);background:radial-gradient(closest-side, rgba(233,107,42,0.22), transparent 70%);"
    ></div>

    <div class="relative aspect-[16/10] min-h-[460px] sm:min-h-[520px] w-full">
      {nodes.map((n) => {
        const isCenter = n.id === "stack";
        const base = `absolute -translate-x-1/2 -translate-y-1/2 ${isCenter ? "w-[240px] sm:w-[280px]" : "w-[220px] sm:w-[240px]"}`;
        const inner = `relative panel rounded-2xl p-4 transition-all ${
          isCenter ? "ring-1 ring-[color:var(--color-blade-500)]/40" : ""
        }`;
        const style = `left:${n.cx}%; top:${n.cy}%;`;
        const content = (
          <article class={inner}>
            <div class="flex items-start justify-between mb-2">
              <span class="font-mono text-lg" style={`color: ${n.glyphColor};`}>{n.glyph}</span>
              <span class="mono text-[9px] tracking-[0.14em] uppercase px-1.5 py-0.5 border border-[color:var(--color-ink-600)] text-[color:var(--color-ink-400)]">
                {n.tag}
              </span>
            </div>
            <div class="text-[14px] font-semibold text-[color:var(--color-ink-50)] tracking-tight">{n.title}</div>
            <p class="mt-1 text-[12px] text-[color:var(--color-ink-400)] leading-snug">{n.body}</p>
            {isCenter && (
              <span class="absolute -top-2 -right-2 inline-flex items-center gap-1 text-[9px] uppercase tracking-[0.14em] bg-[color:var(--color-blade-500)] text-[color:var(--color-ink-950)] px-1.5 py-0.5 font-semibold">
                you are here
              </span>
            )}
            {!isCenter && (
              <div class="mt-3 mono text-[10px] tracking-[0.12em] uppercase text-[color:var(--color-blade-400)] opacity-0 transition-opacity duration-200 constellation-link">
                ↔ {n.link} Stack
              </div>
            )}
          </article>
        );
        return (
          <div class={base} style={style} data-node-id={n.id}>
            {n.url ? (
              <a
                href={n.url}
                target="_blank"
                rel="noopener noreferrer"
                class="block constellation-node"
                aria-label={`${n.title} — ${n.tag}`}
              >
                {content}
              </a>
            ) : (
              <div class="constellation-node">{content}</div>
            )}
          </div>
        );
      })}
    </div>
  </div>

  <div class="mt-6 flex flex-wrap gap-x-6 gap-y-2 text-[12px] text-[color:var(--color-ink-500)]">
    <span>→ Stack writes through Phantom</span>
    <span>→ ashlr-plugin shares the same <code class="mono text-[color:var(--color-ink-300)]">.stack.toml</code></span>
    <span>→ ashlrcode respects the same secret slots</span>
  </div>
</section>

<style>
  .constellation-line {
    transition: stroke-opacity 220ms ease, stroke-width 220ms ease;
  }
  .constellation-node:hover .constellation-link {
    opacity: 1;
  }
  /* Highlight the matching line when a node is hovered */
  [data-node-id="phantom"]:hover ~ * .constellation-line-phantom,
  .constellation-wrap:has([data-node-id="phantom"] .constellation-node:hover) .constellation-line-phantom {
    stroke-width: 0.45;
  }
  .constellation-wrap:has([data-node-id="plugin"] .constellation-node:hover) .constellation-line-plugin {
    stroke-width: 0.45;
  }
  .constellation-wrap:has([data-node-id="ashlrcode"] .constellation-node:hover) .constellation-line-ashlrcode {
    stroke-width: 0.45;
  }
</style>
