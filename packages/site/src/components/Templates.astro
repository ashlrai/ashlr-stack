---
import { getIconPath } from "~/lib/icons";
import { PROVIDERS } from "~/lib/providers";
import TemplateExplorer, { type Template } from "./TemplateExplorer";

interface TemplateEntry {
  id: string;
  title: string;
  blurb: string;
  /** Display names from providers.ts (for icon resolution). */
  stack: string[];
  /** Ref names from providers-ref.ts (for recipe generation). */
  refNames: string[];
  accent?: string;
}

const TEMPLATES: TemplateEntry[] = [
  {
    id: "nextjs-supabase-posthog",
    title: "Next.js + Supabase + PostHog",
    blurb: "App Router, Supabase Auth + Postgres, PostHog events from server actions.",
    stack: ["Vercel", "Supabase", "PostHog"],
    refNames: ["vercel", "supabase", "posthog"],
    accent: "3ECF8E",
  },
  {
    id: "nextjs-neon-vercel-sentry",
    title: "Next.js + Neon + Vercel + Sentry",
    blurb: "Serverless Postgres with Drizzle, deployed to Vercel, observed by Sentry.",
    stack: ["Vercel", "Neon", "Sentry"],
    refNames: ["vercel", "neon", "sentry"],
    accent: "8B5CF6",
  },
  {
    id: "claude-agent-openai-anthropic",
    title: "Claude Code agent — OpenAI + Anthropic",
    blurb: "MCP-first TypeScript agent with side-by-side model comparison and tool use.",
    stack: ["Anthropic", "OpenAI", "GitHub"],
    refNames: ["anthropic", "openai", "github"],
    accent: "D97757",
  },
  {
    id: "supabase-posthog-sentry-resend",
    title: "SaaS starter — Supabase · PostHog · Sentry · Resend",
    blurb: "Auth, analytics, errors, and transactional email — wired from day one.",
    stack: ["Supabase", "PostHog", "Sentry", "Resend"],
    refNames: ["supabase", "posthog", "sentry", "resend"],
    accent: "F54E00",
  },
  {
    id: "cloudflare-turso-clerk",
    title: "Cloudflare Workers + Turso + Clerk",
    blurb: "Edge API on Workers, libSQL at the edge via Turso, users via Clerk.",
    stack: ["Cloudflare", "Turso", "Clerk"],
    refNames: ["cloudflare", "turso", "clerk"],
    accent: "F38020",
  },
];

const providerMap = new Map(PROVIDERS.map((p) => [p.name, p]));

const templates: Template[] = TEMPLATES.map((t) => ({
  id: t.id,
  title: t.title,
  blurb: t.blurb,
  refNames: t.refNames,
  accent: t.accent,
  iconPaths: t.stack.map((name) => {
    const p = providerMap.get(name);
    return p ? getIconPath(p.slug) : null;
  }),
  iconNames: t.stack,
  iconColors: t.stack.map((name) => providerMap.get(name)?.color ?? "6b8097"),
}));
---

<section id="templates" class="relative mx-auto max-w-[1240px] px-6 sm:px-10 pt-16 sm:pt-20 pb-24 sm:pb-28">
  <div class="section-rule mb-10">
    <span>§ 06 · Starter stacks · {String(TEMPLATES.length).padStart(2, "0")}</span>
  </div>

  <header class="max-w-[760px] mb-12" data-reveal>
    <h2 class="display text-[color:var(--color-ink-50)]" style="font-size: clamp(32px, 4.4vw, 56px);">
      Opinionated starters, <span class="display-accent">wired end-to-end.</span>
    </h2>
    <p class="mt-5 text-[15px] leading-[1.6] text-[color:var(--color-ink-300)] max-w-[620px]">
      Each template is a real stack — not a boilerplate dump. Pick one; see the exact
      <code class="mono text-[color:var(--color-ink-100)]">stack add</code> invocations,
      every env var that lands in <code class="mono text-[color:var(--color-ink-100)]">.env</code>,
      and the <code class="mono text-[color:var(--color-ink-100)]">.mcp.json</code> your
      Claude Code session will see.
    </p>
  </header>

  <div data-reveal>
    <TemplateExplorer templates={templates} client:visible />
  </div>

  <div class="mt-8 flex items-center gap-3 text-sm text-[color:var(--color-ink-400)]">
    <span class="w-1 h-1 rounded-full bg-[color:var(--color-ink-500)]"></span>
    Don't see your stack? <code class="mono text-[color:var(--color-ink-200)]">stack init</code> opens an interactive picker — tick providers, stack provisions them.
  </div>
</section>
