---
/**
 * Static isometric silhouette of the hero stack, rendered during SSR so
 * there's no empty box + layout shift before <HeroStack3D client:visible />
 * hydrates. Once the island mounts, the Canvas is absolutely-positioned
 * over this.
 */

const TIERS = [
  "HUMAN / AGENT",
  "CLI / MCP",
  "AI APIS",
  "OBSERVABILITY",
  "DEPLOY",
  "DATABASES",
  "AUTH",
  "PHANTOM",
];

const plateWidth = 360;
const plateDepth = 170;
const gap = 44;
const skewX = 30;  // horizontal shear gives the iso top-face
const startX = 70;
const startY = 90;
---

<svg
  viewBox="0 0 600 720"
  width="100%"
  height="100%"
  aria-hidden="true"
  class="hero-fallback"
  style="display: block;"
>
  <defs>
    <linearGradient id="plate-top" x1="0" x2="1" y1="0" y2="0">
      <stop offset="0%" stop-color="#1e2630" />
      <stop offset="100%" stop-color="#131820" />
    </linearGradient>
    <linearGradient id="plate-top-accent" x1="0" x2="1" y1="0" y2="0">
      <stop offset="0%" stop-color="#3a2010" />
      <stop offset="100%" stop-color="#241008" />
    </linearGradient>
    <linearGradient id="plate-side" x1="0" x2="0" y1="0" y2="1">
      <stop offset="0%" stop-color="#141820" />
      <stop offset="100%" stop-color="#0b0e14" />
    </linearGradient>
  </defs>

  {TIERS.map((label, i) => {
    const accent = i === TIERS.length - 1;
    const y = startY + i * gap;
    // Approximate iso projection:
    //   top face = parallelogram skewed on X
    //   side face = small dark rect hanging below
    const topFill = accent ? "url(#plate-top-accent)" : "url(#plate-top)";
    const stroke = accent ? "#f5883e" : "#39556f";
    return (
      <g transform={`translate(${startX} ${y})`}>
        {/* Top face — parallelogram */}
        <polygon
          points={`0,0 ${plateWidth},0 ${plateWidth - skewX},${plateDepth * 0.18} ${-skewX},${plateDepth * 0.18}`}
          fill={topFill}
          stroke={stroke}
          stroke-width="1"
        />
        {/* Front face — thin slab */}
        <rect
          x={-skewX}
          y={plateDepth * 0.18}
          width={plateWidth}
          height="6"
          fill="url(#plate-side)"
          stroke={stroke}
          stroke-width="0.5"
          stroke-opacity="0.4"
        />
        {/* Side face — right edge */}
        <polygon
          points={`${plateWidth},0 ${plateWidth - skewX},${plateDepth * 0.18} ${plateWidth - skewX},${plateDepth * 0.18 + 6} ${plateWidth},6`}
          fill="#0d1218"
          stroke={stroke}
          stroke-width="0.5"
          stroke-opacity="0.4"
        />
        {/* Etched label on top face */}
        <text
          x="18"
          y={plateDepth * 0.18 * 0.5 + 4}
          fill={accent ? "#f9a877" : "#c4ccd5"}
          font-family="ui-monospace, 'SF Mono', Menlo, monospace"
          font-size="10"
          letter-spacing="1.4"
        >
          {label}
        </text>
        <text
          x={plateWidth - 30}
          y={plateDepth * 0.18 * 0.5 + 4}
          fill={accent ? "#f5883e" : "#6b8097"}
          font-family="ui-monospace, 'SF Mono', Menlo, monospace"
          font-size="11"
          text-anchor="end"
          letter-spacing="1.2"
        >
          {String(TIERS.length - i).padStart(2, "0")}
        </text>
      </g>
    );
  })}

  {/* Amber pool glow under the last plate */}
  <ellipse
    cx="250"
    cy={startY + TIERS.length * gap + 20}
    rx="210"
    ry="18"
    fill="#e96b2a"
    opacity="0.18"
  />

  {/* Corner tick marks — viewfinder feel */}
  <g stroke="#e96b2a" stroke-width="1.5" fill="none" opacity="0.6">
    <path d="M 20 20 L 36 20 M 20 20 L 20 36" />
    <path d="M 580 20 L 564 20 M 580 20 L 580 36" />
    <path d="M 20 700 L 36 700 M 20 700 L 20 684" />
    <path d="M 580 700 L 564 700 M 580 700 L 580 684" />
  </g>
</svg>

<style>
  .hero-fallback {
    opacity: 0.92;
  }
</style>
