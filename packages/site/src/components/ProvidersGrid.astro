---
import { PROVIDERS } from "~/lib/providers";
import { getIconPath } from "~/lib/icons";
import StackBuilder from "./StackBuilder";

const iconPaths: Record<string, string | null> = Object.fromEntries(
  PROVIDERS.map((p) => [p.slug, getIconPath(p.slug)]),
);
---

<section id="providers" class="relative mx-auto max-w-[1240px] px-6 sm:px-10 pt-16 sm:pt-20 pb-24 sm:pb-28">
  <div class="section-rule mb-10">
    <span>§ 04 · Stack builder · {String(PROVIDERS.length).padStart(2, "0")} providers</span>
  </div>

  <header class="max-w-[760px]" data-reveal>
    <h2 class="display text-[color:var(--color-ink-50)]" style="font-size: clamp(32px, 4.4vw, 56px);">
      Pick your stack. See the
      <span class="mono text-[color:var(--color-blade-400)] text-[0.76em]" style="letter-spacing: -0.01em">recipe</span>
      <span class="display-accent">— live.</span>
    </h2>
    <p class="mt-5 text-[15px] leading-[1.6] text-[color:var(--color-ink-300)] max-w-[620px]">
      Click any provider to inspect the real <span class="mono text-[color:var(--color-ink-100)]">stack add</span>
      invocation, every env var it writes, and — where present — the MCP entry Stack drops
      into <span class="mono text-[color:var(--color-ink-100)]">.mcp.json</span>. Tick as many as you want
      and export the whole recipe.
    </p>
  </header>

  <div class="mt-12" data-reveal>
    <StackBuilder iconPaths={iconPaths} client:visible />
  </div>

  <p class="mt-14 text-xs text-[color:var(--color-ink-500)] max-w-2xl">
    Brand marks provided by <a class="underline decoration-white/20 underline-offset-2 hover:text-[color:var(--color-ink-300)]" href="https://simpleicons.org" rel="noopener noreferrer" target="_blank">simple-icons</a>
    and used for identification. All trademarks are property of their respective owners.
    Secret values never leave your machine — Phantom resolves <span class="mono">phantom://</span> slots locally at read-time.
  </p>
</section>
