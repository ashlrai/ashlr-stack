---
/**
 * Ashlr Stack — "Orbit & Spire" mark.
 *
 * Two elements, deliberately minimal:
 *   1. A steel → amber orbital ring with a single bright satellite node at
 *      ~30 deg (top-right) and a dashed micro-arc opposite it. Echoes the
 *      concentric orbits + dashed guides in <StackOrbit /> without copying.
 *   2. A central amber spire — a faceted triangular prism. The right facet
 *      catches light (blade-500 → blade-600 gradient); the left facet sits in
 *      ink shadow with an amber keyline. A soft amber base glow grounds it.
 *
 * Reads at 16 px (favicon: ring + dot + triangle silhouette), scales cleanly
 * to 512 px (facets, gradient, glow, dashed arc all activate).
 *
 * Amber-first but not amber-only — steel carries the ring, ink carries the
 * shadow facet, amber carries the satellite, keyline, and lit facet. Preserves
 * the Anduril-industrial feel.
 *
 * Variants:
 *   mark     — icon only, square (favicons, corner marks)
 *   chip     — icon + "stack" wordmark inline (nav + footer)
 *   wordmark — large hero/OG use, Monument Grotesk display
 *
 * idSuffix is load-bearing: every <linearGradient|radialGradient|clipPath>
 * id is namespaced so multiple <Logo /> instances on one page (Nav + Footer +
 * DocsHeader) don't collide.
 */
export interface Props {
  variant?: "chip" | "mark" | "wordmark";
  size?: number;
  class?: string;
  /** Unique suffix for gradient ids when multiple Logo instances coexist. */
  idSuffix?: string;
}
const { variant = "chip", size = 28, class: className = "", idSuffix = "" } = Astro.props;
const sid = `logo${idSuffix}`;

/**
 * Shared <defs> + glyph drawing. The SVG uses a 32×32 viewBox; center at
 * (16, 16). Ring radius 12.5, spire inscribed inside ring (apex at y=7.5,
 * base at y=22.5, half-width 6).
 *
 * Every id is suffixed with `_<variant>` so the three variant SVGs can safely
 * coexist in one DOM (e.g. wordmark + chip on the same page).
 */
const spire = {
  apexX: 16, apexY: 7.5,
  baseLX: 10, baseRX: 22, baseY: 22.5,
};
---

{variant === "mark" && (
  <svg
    viewBox="0 0 32 32"
    width={size}
    height={size}
    fill="none"
    class={className}
    aria-label="Ashlr Stack"
    role="img"
  >
    <defs>
      {/* Ring: steel at the bottom fading up to amber at the top — suggests
          the ring is "lit" from the satellite's angle. */}
      <linearGradient id={`${sid}-ring-m`} x1="0" y1="1" x2="1" y2="0">
        <stop offset="0%" stop-color="#39556f" stop-opacity="0.55" />
        <stop offset="55%" stop-color="#6b8097" stop-opacity="0.9" />
        <stop offset="100%" stop-color="#f5883e" />
      </linearGradient>
      {/* Lit facet of the spire: bright amber → deeper amber. */}
      <linearGradient id={`${sid}-facet-m`} x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#f5883e" />
        <stop offset="100%" stop-color="#c2521c" />
      </linearGradient>
      {/* Shadow facet: deep ink with a hint of warm phantom at the base. */}
      <linearGradient id={`${sid}-shadow-m`} x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#1a1f26" />
        <stop offset="100%" stop-color="#2a1a10" />
      </linearGradient>
      {/* Ambient base glow under the spire. */}
      <radialGradient id={`${sid}-glow-m`} cx="50%" cy="90%" r="60%">
        <stop offset="0%" stop-color="#e96b2a" stop-opacity="0.55" />
        <stop offset="70%" stop-color="#e96b2a" stop-opacity="0" />
      </radialGradient>
      {/* Satellite node halo. */}
      <radialGradient id={`${sid}-sat-m`} cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#fbe1cf" />
        <stop offset="35%" stop-color="#f5883e" />
        <stop offset="100%" stop-color="#e96b2a" />
      </radialGradient>
    </defs>

    {/* Soft ground glow */}
    <ellipse cx="16" cy="27" rx="10" ry="2.25" fill={`url(#${sid}-glow-m)`} />

    {/* Orbital ring — not a perfect circle stroke; it's a pair of arcs so we
        can break it with the dashed micro-arc opposite the satellite. The
        satellite sits at polar (r=12.5, theta = -60deg from center); the
        dashed arc sits on the lower-left (~150deg → 210deg). */}
    <g>
      {/* Main ring (solid, two arcs skipping the lower-left dashed segment) */}
      <path
        d="M 16 3.5 A 12.5 12.5 0 0 1 26.25 22.75"
        stroke={`url(#${sid}-ring-m)`}
        stroke-width="1.4"
        stroke-linecap="round"
        fill="none"
      />
      <path
        d="M 8.3 26.65 A 12.5 12.5 0 0 1 4.08 12.35"
        stroke={`url(#${sid}-ring-m)`}
        stroke-width="1.4"
        stroke-linecap="round"
        fill="none"
      />
      {/* Dashed lower arc — the "orbit" trail, echoing StackOrbit guides */}
      <path
        d="M 4.08 12.35 A 12.5 12.5 0 0 1 8.3 26.65"
        stroke="#f5883e"
        stroke-opacity="0.45"
        stroke-width="0.7"
        stroke-dasharray="0.6 1.8"
        stroke-linecap="round"
        fill="none"
      />
    </g>

    {/* Spire — drawn as two facets sharing the apex→base-center seam */}
    <g>
      {/* Shadow (left) facet */}
      <path
        d={`M ${spire.apexX} ${spire.apexY} L 16 ${spire.baseY} L ${spire.baseLX} ${spire.baseY} Z`}
        fill={`url(#${sid}-shadow-m)`}
      />
      {/* Lit (right) facet */}
      <path
        d={`M ${spire.apexX} ${spire.apexY} L ${spire.baseRX} ${spire.baseY} L 16 ${spire.baseY} Z`}
        fill={`url(#${sid}-facet-m)`}
      />
      {/* Amber keyline around the full silhouette */}
      <path
        d={`M ${spire.apexX} ${spire.apexY} L ${spire.baseRX} ${spire.baseY} L ${spire.baseLX} ${spire.baseY} Z`}
        fill="none"
        stroke="#f5883e"
        stroke-width="1.05"
        stroke-linejoin="miter"
      />
      {/* Center seam (apex → base midpoint) — a hair of amber to catch the
          eye at large sizes; invisible at 16 px because of antialiasing. */}
      <line
        x1={spire.apexX}
        y1={spire.apexY}
        x2="16"
        y2={spire.baseY}
        stroke="#fbe1cf"
        stroke-opacity="0.18"
        stroke-width="0.4"
      />
    </g>

    {/* Satellite node on the ring at polar (-60deg from +x axis), i.e.
        top-right. Position: cx = 16 + 12.5*cos(-60deg) ≈ 22.25,
        cy = 16 + 12.5*sin(-60deg) ≈ 5.18. Rounded to clean increments. */}
    <circle cx="22.25" cy="5.18" r="2" fill={`url(#${sid}-sat-m)`} />
    <circle cx="22.25" cy="5.18" r="0.7" fill="#fbe1cf" />
  </svg>
)}

{variant === "chip" && (
  <span class={`inline-flex items-center gap-2.5 ${className}`} aria-label="Ashlr Stack">
    <svg viewBox="0 0 32 32" width={size} height={size} fill="none" aria-hidden="true" role="img">
      <defs>
        <linearGradient id={`${sid}-ring-c`} x1="0" y1="1" x2="1" y2="0">
          <stop offset="0%" stop-color="#39556f" stop-opacity="0.55" />
          <stop offset="55%" stop-color="#6b8097" stop-opacity="0.9" />
          <stop offset="100%" stop-color="#f5883e" />
        </linearGradient>
        <linearGradient id={`${sid}-facet-c`} x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#f5883e" />
          <stop offset="100%" stop-color="#c2521c" />
        </linearGradient>
        <linearGradient id={`${sid}-shadow-c`} x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#1a1f26" />
          <stop offset="100%" stop-color="#2a1a10" />
        </linearGradient>
        <radialGradient id={`${sid}-glow-c`} cx="50%" cy="90%" r="60%">
          <stop offset="0%" stop-color="#e96b2a" stop-opacity="0.5" />
          <stop offset="70%" stop-color="#e96b2a" stop-opacity="0" />
        </radialGradient>
        <radialGradient id={`${sid}-sat-c`} cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#fbe1cf" />
          <stop offset="35%" stop-color="#f5883e" />
          <stop offset="100%" stop-color="#e96b2a" />
        </radialGradient>
      </defs>
      <ellipse cx="16" cy="27" rx="10" ry="2.25" fill={`url(#${sid}-glow-c)`} />
      <path d="M 16 3.5 A 12.5 12.5 0 0 1 26.25 22.75" stroke={`url(#${sid}-ring-c)`} stroke-width="1.4" stroke-linecap="round" fill="none" />
      <path d="M 8.3 26.65 A 12.5 12.5 0 0 1 4.08 12.35" stroke={`url(#${sid}-ring-c)`} stroke-width="1.4" stroke-linecap="round" fill="none" />
      <path d="M 4.08 12.35 A 12.5 12.5 0 0 1 8.3 26.65" stroke="#f5883e" stroke-opacity="0.45" stroke-width="0.7" stroke-dasharray="0.6 1.8" stroke-linecap="round" fill="none" />
      <path d={`M ${spire.apexX} ${spire.apexY} L 16 ${spire.baseY} L ${spire.baseLX} ${spire.baseY} Z`} fill={`url(#${sid}-shadow-c)`} />
      <path d={`M ${spire.apexX} ${spire.apexY} L ${spire.baseRX} ${spire.baseY} L 16 ${spire.baseY} Z`} fill={`url(#${sid}-facet-c)`} />
      <path d={`M ${spire.apexX} ${spire.apexY} L ${spire.baseRX} ${spire.baseY} L ${spire.baseLX} ${spire.baseY} Z`} fill="none" stroke="#f5883e" stroke-width="1.05" stroke-linejoin="miter" />
      <circle cx="22.25" cy="5.18" r="2" fill={`url(#${sid}-sat-c)`} />
      <circle cx="22.25" cy="5.18" r="0.7" fill="#fbe1cf" />
    </svg>
    <span
      class="text-[14px] font-medium tracking-[0.14em] uppercase text-[color:var(--color-ink-50)]"
      style="font-family: var(--font-display); font-stretch: 112%;"
    >stack</span>
  </span>
)}

{variant === "wordmark" && (
  <span
    class={`display text-[color:var(--color-ink-50)] inline-flex items-baseline gap-3 ${className}`}
    style="font-size: clamp(28px, 5vw, 48px); letter-spacing: -0.03em;"
    aria-label="Ashlr Stack"
  >
    <svg
      viewBox="0 0 32 32"
      width="1em"
      height="1em"
      fill="none"
      style="transform: translateY(0.08em);"
      aria-hidden="true"
    >
      <defs>
        <linearGradient id={`${sid}-ring-w`} x1="0" y1="1" x2="1" y2="0">
          <stop offset="0%" stop-color="#39556f" stop-opacity="0.55" />
          <stop offset="55%" stop-color="#6b8097" stop-opacity="0.9" />
          <stop offset="100%" stop-color="#f5883e" />
        </linearGradient>
        <linearGradient id={`${sid}-facet-w`} x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%" stop-color="#f5883e" />
          <stop offset="100%" stop-color="#c2521c" />
        </linearGradient>
        <linearGradient id={`${sid}-shadow-w`} x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#1a1f26" />
          <stop offset="100%" stop-color="#2a1a10" />
        </linearGradient>
        <radialGradient id={`${sid}-glow-w`} cx="50%" cy="90%" r="60%">
          <stop offset="0%" stop-color="#e96b2a" stop-opacity="0.5" />
          <stop offset="70%" stop-color="#e96b2a" stop-opacity="0" />
        </radialGradient>
        <radialGradient id={`${sid}-sat-w`} cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#fbe1cf" />
          <stop offset="35%" stop-color="#f5883e" />
          <stop offset="100%" stop-color="#e96b2a" />
        </radialGradient>
      </defs>
      <ellipse cx="16" cy="27" rx="10" ry="2.25" fill={`url(#${sid}-glow-w)`} />
      <path d="M 16 3.5 A 12.5 12.5 0 0 1 26.25 22.75" stroke={`url(#${sid}-ring-w)`} stroke-width="1.4" stroke-linecap="round" fill="none" />
      <path d="M 8.3 26.65 A 12.5 12.5 0 0 1 4.08 12.35" stroke={`url(#${sid}-ring-w)`} stroke-width="1.4" stroke-linecap="round" fill="none" />
      <path d="M 4.08 12.35 A 12.5 12.5 0 0 1 8.3 26.65" stroke="#f5883e" stroke-opacity="0.45" stroke-width="0.7" stroke-dasharray="0.6 1.8" stroke-linecap="round" fill="none" />
      <path d={`M ${spire.apexX} ${spire.apexY} L 16 ${spire.baseY} L ${spire.baseLX} ${spire.baseY} Z`} fill={`url(#${sid}-shadow-w)`} />
      <path d={`M ${spire.apexX} ${spire.apexY} L ${spire.baseRX} ${spire.baseY} L 16 ${spire.baseY} Z`} fill={`url(#${sid}-facet-w)`} />
      <path d={`M ${spire.apexX} ${spire.apexY} L ${spire.baseRX} ${spire.baseY} L ${spire.baseLX} ${spire.baseY} Z`} fill="none" stroke="#f5883e" stroke-width="1.05" stroke-linejoin="miter" />
      <circle cx="22.25" cy="5.18" r="2" fill={`url(#${sid}-sat-w)`} />
      <circle cx="22.25" cy="5.18" r="0.7" fill="#fbe1cf" />
    </svg>
    <span>stack</span>
  </span>
)}
