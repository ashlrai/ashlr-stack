---
/**
 * ▲ stack — the mark is a triangular silhouette of the 8-tier stack.
 *
 * Outer amber outline, steel gradient fill, 7 hairline stripes inside
 * evoking the plate boundaries. The bottom slice (Phantom tier) glows
 * warmer amber.
 *
 * Variants:
 *   mark     — just the glyph (favicons, app icons, corner marks)
 *   chip     — glyph + "stack" wordmark inline (nav + footer)
 *   wordmark — large hero/OG use, Monument Grotesk
 */
export interface Props {
  variant?: "chip" | "mark" | "wordmark";
  size?: number;
  class?: string;
  /** Unique suffix for gradient ids when multiple Logo instances coexist. */
  idSuffix?: string;
}
const { variant = "chip", size = 28, class: className = "", idSuffix = "" } = Astro.props;
const sid = `logo${idSuffix}`;

const stripeYs = [6.875, 9.75, 12.625, 15.5, 18.375, 21.25, 24.125];
---

{(variant === "mark") && (
  <svg
    viewBox="0 0 32 32"
    width={size}
    height={size}
    fill="none"
    class={className}
    aria-label="Ashlr Stack"
    role="img"
  >
    <defs>
      <linearGradient id={`${sid}-steel`} x1="0" x2="0" y1="0" y2="1">
        <stop offset="0%" stop-color="#2a3340" />
        <stop offset="60%" stop-color="#1a1f26" />
        <stop offset="100%" stop-color="#0f1419" />
      </linearGradient>
      <linearGradient id={`${sid}-phantom`} x1="0" x2="0" y1="0" y2="1">
        <stop offset="0%" stop-color="#3a2212" />
        <stop offset="100%" stop-color="#1a0e08" />
      </linearGradient>
      <radialGradient id={`${sid}-glow`} cx="50%" cy="100%" r="55%">
        <stop offset="0%" stop-color="#e96b2a" stop-opacity="0.7" />
        <stop offset="70%" stop-color="#e96b2a" stop-opacity="0" />
      </radialGradient>
      <clipPath id={`${sid}-clip`}>
        <path d="M16 4 L28 27 L4 27 Z" />
      </clipPath>
    </defs>
    <ellipse cx="16" cy="30" rx="12" ry="3" fill={`url(#${sid}-glow)`} />
    <g clip-path={`url(#${sid}-clip)`}>
      <rect x="0" y="0" width="32" height="23" fill={`url(#${sid}-steel)`} />
      <rect x="0" y="24.125" width="32" height="2.875" fill={`url(#${sid}-phantom)`} />
      {stripeYs.map((y) => (
        <line x1="0" x2="32" y1={y} y2={y} stroke="#e96b2a" stroke-width="0.35" stroke-opacity={y === 24.125 ? 0.85 : 0.25} />
      ))}
    </g>
    <path d="M16 4 L28 27 L4 27 Z" fill="none" stroke="#e96b2a" stroke-width="1.3" stroke-linejoin="miter" />
  </svg>
)}

{variant === "chip" && (
  <span class={`inline-flex items-center gap-2.5 ${className}`} aria-label="Ashlr Stack">
    <svg viewBox="0 0 32 32" width={size} height={size} fill="none" aria-hidden="true" role="img">
      <defs>
        <linearGradient id={`${sid}-steel-c`} x1="0" x2="0" y1="0" y2="1">
          <stop offset="0%" stop-color="#2a3340" />
          <stop offset="60%" stop-color="#1a1f26" />
          <stop offset="100%" stop-color="#0f1419" />
        </linearGradient>
        <linearGradient id={`${sid}-phantom-c`} x1="0" x2="0" y1="0" y2="1">
          <stop offset="0%" stop-color="#3a2212" />
          <stop offset="100%" stop-color="#1a0e08" />
        </linearGradient>
        <clipPath id={`${sid}-clip-c`}>
          <path d="M16 4 L28 27 L4 27 Z" />
        </clipPath>
      </defs>
      <g clip-path={`url(#${sid}-clip-c)`}>
        <rect x="0" y="0" width="32" height="23" fill={`url(#${sid}-steel-c)`} />
        <rect x="0" y="24.125" width="32" height="2.875" fill={`url(#${sid}-phantom-c)`} />
        {stripeYs.map((y) => (
          <line x1="0" x2="32" y1={y} y2={y} stroke="#e96b2a" stroke-width="0.35" stroke-opacity={y === 24.125 ? 0.85 : 0.25} />
        ))}
      </g>
      <path d="M16 4 L28 27 L4 27 Z" fill="none" stroke="#e96b2a" stroke-width="1.3" stroke-linejoin="miter" />
    </svg>
    <span
      class="text-[14px] font-medium tracking-[0.14em] uppercase text-[color:var(--color-ink-50)]"
      style="font-family: var(--font-display); font-stretch: 112%;"
    >stack</span>
  </span>
)}

{variant === "wordmark" && (
  <span
    class={`display text-[color:var(--color-ink-50)] inline-flex items-baseline gap-3 ${className}`}
    style="font-size: clamp(28px, 5vw, 48px); letter-spacing: -0.03em;"
    aria-label="Ashlr Stack"
  >
    <svg
      viewBox="0 0 32 32"
      width="1em"
      height="1em"
      fill="none"
      style="transform: translateY(0.08em);"
      aria-hidden="true"
    >
      <defs>
        <linearGradient id={`${sid}-steel-w`} x1="0" x2="0" y1="0" y2="1">
          <stop offset="0%" stop-color="#2a3340" />
          <stop offset="60%" stop-color="#1a1f26" />
          <stop offset="100%" stop-color="#0f1419" />
        </linearGradient>
        <linearGradient id={`${sid}-phantom-w`} x1="0" x2="0" y1="0" y2="1">
          <stop offset="0%" stop-color="#3a2212" />
          <stop offset="100%" stop-color="#1a0e08" />
        </linearGradient>
        <clipPath id={`${sid}-clip-w`}>
          <path d="M16 4 L28 27 L4 27 Z" />
        </clipPath>
      </defs>
      <g clip-path={`url(#${sid}-clip-w)`}>
        <rect x="0" y="0" width="32" height="23" fill={`url(#${sid}-steel-w)`} />
        <rect x="0" y="24.125" width="32" height="2.875" fill={`url(#${sid}-phantom-w)`} />
        {stripeYs.map((y) => (
          <line x1="0" x2="32" y1={y} y2={y} stroke="#e96b2a" stroke-width="0.35" stroke-opacity={y === 24.125 ? 0.85 : 0.25} />
        ))}
      </g>
      <path d="M16 4 L28 27 L4 27 Z" fill="none" stroke="#e96b2a" stroke-width="1.3" stroke-linejoin="miter" />
    </svg>
    <span>stack</span>
  </span>
)}
