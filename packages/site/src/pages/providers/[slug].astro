---
/**
 * /providers/[slug] — one page per provider in the canonical catalog.
 *
 * Data source: packages/core/src/catalog.ts (PROVIDERS_REF). This is the
 * single-source-of-truth catalog for CLI + MCP + AI recommender + site.
 * Adding a provider to catalog.ts automatically mints a page here at
 * build time.
 *
 * Content shape (each page, ~400-700 words rendered from metadata):
 *  1. Hero — displayName + category + logo + one-line blurb + `stack add` snippet
 *  2. Auth flow explainer (from authKind)
 *  3. Secret slots (from secrets[])
 *  4. MCP wiring status (from mcp)
 *  5. Example recipe (link templates that include this provider)
 *  6. Related providers (others in same category, limit 5)
 *  7. FAQ (generic trio: "do I need an account?" / "is the key rotated?" /
 *     "can I use an existing project?")
 *  8. Dashboard + docs outbound links
 *
 * JSON-LD: TechArticle (via Docs layout) + BreadcrumbList + FAQPage.
 */

import Docs from "~/layouts/Docs.astro";
import { Code } from "astro:components";
import { PROVIDERS_REF, type ProviderRef } from "~/lib/providers-ref";
import { PROVIDERS } from "~/lib/providers";
import { getIconPath } from "~/lib/icons";
import { breadcrumbSchema, faqPageSchema } from "~/lib/structured-data";
import { SITE_URL } from "~/lib/og";

export function getStaticPaths() {
  return PROVIDERS_REF.map((p) => ({
    params: { slug: p.name },
    props: { provider: p },
  }));
}

interface Props {
  provider: ProviderRef;
}

const { provider: p } = Astro.props as Props;

// Look up brand color + simple-icons slug from the site's display catalog.
// catalog.ts is the canonical source for auth/secrets/blurb but doesn't carry
// brand color; providers.ts does. Joining on `name` gives us both.
const display = PROVIDERS.find((q) => q.name === p.displayName) ??
  PROVIDERS.find((q) => q.slug === p.name) ??
  null;
const brandColor = display?.color ?? "e96b2a"; // fallback: Stack amber
const iconSlug = display?.slug ?? p.name;
const iconPath = getIconPath(iconSlug);

const AUTH_EXPLAINERS: Record<string, string> = {
  oauth_pkce:
    "Stack runs the provider's OAuth (PKCE) flow in your browser. You click Authorise, and Stack captures the token via a one-shot localhost callback server.",
  oauth_device:
    "Stack runs the OAuth device flow. You paste a code into the provider's authorization page; Stack polls until you confirm.",
  pat: "Paste a personal access token (PAT) once. Stack verifies it against the provider's API before writing to Phantom.",
  api_key: "Paste a long-lived API key once. Stack verifies it against the provider's API before writing to Phantom.",
};
const AUTH_LABELS: Record<string, string> = {
  oauth_pkce: "OAuth (PKCE)",
  oauth_device: "OAuth (device)",
  pat: "PAT",
  api_key: "API key",
};

/**
 * Category-specific `stack recommend "..."` example prompts. Keeps the JSX
 * clean and makes per-category copy editable in one place.
 */
const CATEGORY_BRIEFS: Record<string, string> = {
  Database: "serverless postgres for a B2B SaaS",
  Payments: "accept payments from customers",
  AI: "LLM provider for a coding assistant",
  Deploy: "host a Next.js frontend",
  Errors: "error + performance tracking",
  Analytics: "product analytics and feature flags",
  Auth: "drop-in user auth for my app",
  Email: "transactional email for my app",
  Code: "git hosting and CI",
  Tickets: "issue tracking for my team",
  Cloud: "raw cloud infrastructure for scale",
};

const authExplainer =
  AUTH_EXPLAINERS[p.authKind] ??
  "Stack runs the provider's auth flow and stores the result in Phantom.";
const authLabel = AUTH_LABELS[p.authKind] ?? p.authKind;
const recommendBrief =
  CATEGORY_BRIEFS[p.category] ?? `I need a ${p.category.toLowerCase()} provider`;

/**
 * Single source of truth for the 3 FAQ items — rendered once for the FAQPage
 * JSON-LD and again in the visible markup below. Keeping one array prevents
 * prose drift between the schema and the page.
 */
const FAQ_ITEMS: Array<{ q: string; a: string }> = [
  {
    q: `Do I need a ${p.displayName} account to use it with Stack?`,
    a: `Yes — Stack provisions ${p.displayName} on your behalf, but it authenticates as you. ${authExplainer} ${
      p.authKind === "oauth_pkce" || p.authKind === "oauth_device"
        ? `If you don't have an account yet, Stack can create one during the OAuth flow.`
        : `If you don't have a credential yet, create one at ${p.dashboard} and paste it once.`
    }`,
  },
  {
    q: `Where does Stack store my ${p.displayName} credentials?`,
    a: `In Phantom Secrets, an E2E-encrypted local vault. Stack writes the secret slot names (${p.secrets.join(", ")}) into .stack.toml — the actual values live only in Phantom and never touch disk in plaintext.`,
  },
  {
    q: `Can I rotate or revoke this integration later?`,
    a: `Yes. Run \`stack remove ${p.name}\` to pull the ${p.displayName} service back out (Phantom secrets deleted, MCP entry removed, .stack.toml cleaned up). Rotate the underlying ${p.displayName} credentials in their dashboard — ${p.dashboard} — and Stack's next \`doctor --fix\` will pick up the new values.`,
  },
];

// Find related providers in the same category (up to 5, excluding self).
const related = PROVIDERS_REF.filter(
  (q) => q.category === p.category && q.name !== p.name,
).slice(0, 5);

// Find templates that include this provider (from packages/core/src/templates
// indirectly — we don't have templates-ref.ts yet, so we hard-list a tiny
// mapping for now. This surfaces real recipes without a second data source.
const TEMPLATES_WITH_PROVIDER: Record<string, string[]> = {
  supabase: ["nextjs-supabase-posthog", "supabase-posthog-sentry-resend"],
  neon: ["nextjs-neon-vercel-sentry"],
  vercel: ["nextjs-neon-vercel-sentry"],
  posthog: ["nextjs-supabase-posthog", "supabase-posthog-sentry-resend"],
  sentry: ["nextjs-neon-vercel-sentry", "supabase-posthog-sentry-resend"],
  resend: ["supabase-posthog-sentry-resend"],
  turso: ["cloudflare-turso-clerk"],
  clerk: ["cloudflare-turso-clerk"],
  cloudflare: ["cloudflare-turso-clerk"],
  openai: ["claude-agent-openai-anthropic"],
  anthropic: ["claude-agent-openai-anthropic"],
};
const templates = TEMPLATES_WITH_PROVIDER[p.name] ?? [];

const pageUrl = `${SITE_URL}/providers/${p.name}/`;
const title = `${p.displayName} — Ashlr Stack Provider`;
const description = `${p.displayName}: ${p.blurb} Wire it into your project with one command via Ashlr Stack.`;

const faq = faqPageSchema(
  FAQ_ITEMS.map((it) => ({ question: it.q, answer: it.a })),
  pageUrl,
);

const breadcrumbs = breadcrumbSchema([
  { name: "Providers", url: "/providers/" },
  { name: p.displayName, url: `/providers/${p.name}/` },
]);
---

<Docs
  title={title}
  description={description}
  eyebrow={`Provider · ${p.category}`}
  extraSchemas={[faq, breadcrumbs]}
>
  <div class="not-prose mb-8 flex items-center gap-4 p-5 panel rounded-xl" style={`border-left: 2px solid #${brandColor};`}>
    {iconPath && (
      <svg
        viewBox="0 0 24 24"
        width="40"
        height="40"
        fill={`#${brandColor}`}
        aria-hidden="true"
        style="flex-shrink: 0"
      >
        <path d={iconPath} />
      </svg>
    )}
    <div class="flex-1 min-w-0">
      <div class="text-[11px] font-semibold uppercase tracking-[0.14em] text-magenta-400 mb-1">
        {p.category} · {authLabel}
      </div>
      <div class="text-[15px] text-ink-100 leading-snug">
        <strong class="font-semibold">{p.displayName}</strong> — {p.blurb}
      </div>
    </div>
    <a
      href={p.dashboard}
      target="_blank"
      rel="noopener"
      class="mono text-[12px] tracking-[0.08em] px-3 py-2 border border-ink-600 text-ink-100 hover:border-magenta-400 hover:text-magenta-200 transition-colors rounded-md flex-shrink-0"
    >
      Dashboard ↗
    </a>
  </div>

  <h2>One command</h2>
  <p>
    Add <strong>{p.displayName}</strong> to any Ashlr Stack project with a single command. Stack runs the auth flow,
    {p.authKind === "oauth_pkce" || p.authKind === "oauth_device" ? ` provisions the upstream resource via the ${p.displayName} Management API, ` : " verifies the credential, "}
    and writes every secret slot into <a href="/docs/phantom/">Phantom</a>.
  </p>

  <Code code={`stack add ${p.name}`} lang="bash" theme="github-dark-dimmed" />

  <p>
    Or describe what you're building and let Claude pick it up via{" "}
    <a href="/docs/recommend/"><code>stack recommend</code></a>:
  </p>

  <Code code={`stack recommend "${recommendBrief}"`} lang="bash" theme="github-dark-dimmed" />

  <h2 id="auth">Auth flow</h2>
  <p>{authExplainer}</p>
  <p>
    <strong>How-to:</strong> {p.howTo}
  </p>

  <h2 id="secrets">Secret slots</h2>
  <p>
    <code>stack add {p.name}</code> writes these <strong>{p.secrets.length}</strong> secret
    {p.secrets.length === 1 ? " slot" : " slots"} into your <a href="/docs/phantom/">Phantom</a> vault:
  </p>
  <ul>
    {p.secrets.map((s) => <li><code>{s}</code></li>)}
  </ul>
  <p>
    The values never leave Phantom in plaintext. Your <code>.env</code> file references slot
    names, and <code>stack exec -- &lt;cmd&gt;</code> swaps them in at process-spawn time via
    Phantom's local proxy.
  </p>

  {p.mcp && (
    <>
      <h2 id="mcp">MCP wiring</h2>
      <p>
        <strong>{p.displayName}</strong> ships an MCP server.
        {" "}
        <code>stack add {p.name}</code> auto-wires it into <code>.mcp.json</code> so your{" "}
        <a href="/docs/mcp/">Claude Code / Cursor / Windsurf</a> session can use it immediately.
      </p>
      <p class="text-ink-400 text-[13px]">
        {p.mcp.detail}
      </p>
    </>
  )}

  {templates.length > 0 && (
    <>
      <h2 id="templates">Starter templates that include {p.displayName}</h2>
      <p>Apply a pre-wired stack with one command:</p>
      <ul>
        {templates.map((t) => (
          <li>
            <code>stack init --template {t}</code>
          </li>
        ))}
      </ul>
    </>
  )}

  {related.length > 0 && (
    <>
      <h2 id="related">Related providers in {p.category}</h2>
      <ul>
        {related.map((r) => (
          <li>
            <a href={`/providers/${r.name}/`}><strong>{r.displayName}</strong></a> — {r.blurb}
          </li>
        ))}
      </ul>
    </>
  )}

  {p.notes && (
    <>
      <h2>v1 notes</h2>
      <p class="text-ink-300">{p.notes}</p>
    </>
  )}

  <h2>FAQ</h2>
  {FAQ_ITEMS.map((item) => (
    <>
      <h3>{item.q}</h3>
      <p>{item.a}</p>
    </>
  ))}

  <h2>Outbound</h2>
  <ul>
    <li><a href={p.dashboard} target="_blank" rel="noopener">{p.displayName} dashboard</a></li>
    <li><a href={p.docs} target="_blank" rel="noopener">{p.displayName} API docs</a></li>
    <li><a href="/docs/providers/">See the full catalog of {PROVIDERS_REF.length} providers →</a></li>
  </ul>
</Docs>
