---
import Base from "~/layouts/Base.astro";
import Hero from "~/components/Hero.astro";
import InstallForClaude from "~/components/InstallForClaude.astro";
import LogoMarquee from "~/components/LogoMarquee";
import OneCommand from "~/components/OneCommand";
import ProvidersGrid from "~/components/ProvidersGrid.astro";
import HowItWorks from "~/components/HowItWorks.astro";
import UseCasesSection from "~/components/UseCasesSection.astro";
import Templates from "~/components/Templates.astro";
import ClaudeCodeDemo from "~/components/ClaudeCodeDemo";
import Constellation from "~/components/Constellation.astro";
import StackREPL from "~/components/StackREPL";
import McpClients from "~/components/McpClients.astro";
import FAQSection from "~/components/FAQSection.astro";
import Footer from "~/components/Footer.astro";
import { PROVIDERS_REF } from "~/lib/providers-ref";
import { PROVIDERS } from "~/lib/providers";
import { getIconPath } from "~/lib/icons";

// Build the marquee payload from the canonical catalog (29 providers). Pull
// color + icon slug from the display catalog by name, so every logo renders
// in its real brand color via the existing simple-icons pipeline.
const marqueeProviders = PROVIDERS_REF.map((p) => {
  const display = PROVIDERS.find((q) => q.name === p.displayName) ??
    PROVIDERS.find((q) => q.slug === p.name);
  return {
    slug: display?.slug ?? p.name,
    name: p.name,
    displayName: p.displayName,
    color: display?.color ?? "e96b2a",
  };
});
const marqueeIconPaths: Record<string, string | null> = Object.fromEntries(
  marqueeProviders.map((p) => [p.slug, getIconPath(p.slug)]),
);

const STATS = [
  { n: String(PROVIDERS_REF.length), l: "providers" },
  { n: "19", l: "mcp tools" },
  { n: "11", l: "categories" },
  { n: "05", l: "templates" },
  { n: "MIT", l: "license" },
];
---

<Base>
  <Hero />

  <!-- § 01a · Supported providers — full-width marquee of all 29 logos.
       Sits directly under the hero so the "what does Stack integrate?"
       question is answered before the install CTA. -->
  <LogoMarquee providers={marqueeProviders} iconPaths={marqueeIconPaths} client:visible />

  <!-- § 01b · Super-clear install CTA. Three paste-ready paths to get
       Stack into any Claude Code / MCP client. -->
  <InstallForClaude />

  <!-- Stat strip — relocated from inside the hero so the hero can breathe. -->
  <section class="relative mx-auto max-w-[1240px] px-6 sm:px-10 pt-10 pb-2">
    <div class="grid grid-cols-2 sm:grid-cols-5 gap-0 border-l border-t border-[color:var(--color-ink-600)]">
      {STATS.map((stat) => (
        <div class="border-r border-b border-[color:var(--color-ink-600)] px-4 py-3">
          <div class="display text-[color:var(--color-ink-50)]" style="font-size: 22px; font-weight: 600;">{stat.n}</div>
          <div class="eyebrow mt-1 text-[9px]">{stat.l}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- § 02 · Before / After — the "one command" moment -->
  <section id="one-command" class="relative mx-auto max-w-[1240px] px-6 sm:px-10 pt-20 sm:pt-24 pb-16 sm:pb-20">
    <div class="section-rule mb-10"><span>§ 02 · Before / After</span></div>

    <header class="max-w-[720px] mb-10" data-reveal>
      <h2 class="display text-[color:var(--color-ink-50)]" style="font-size: clamp(34px, 4.4vw, 56px);">
        Forty-five minutes. Or <span class="display-accent">four seconds</span>.
      </h2>
      <p class="mt-5 text-[15px] leading-[1.6] text-[color:var(--color-ink-300)] max-w-[560px]">
        Wiring a single service the old way vs. <span class="text-[color:var(--color-ink-100)] mono">stack add supabase</span>.
        Scroll through the delta.
      </p>
    </header>

    <OneCommand client:visible />
  </section>

  <!-- § 03 · Interactive — StackREPL -->
  <section id="try-it" class="relative mx-auto max-w-[1240px] px-6 sm:px-10 pt-16 sm:pt-20 pb-20 sm:pb-24">
    <div class="section-rule mb-10"><span>§ 03 · Interactive</span></div>

    <header class="max-w-[720px] mb-10" data-reveal>
      <h2 class="display text-[color:var(--color-ink-50)]" style="font-size: clamp(34px, 4.4vw, 56px);">
        Try it <span class="display-accent">live</span>.
      </h2>
      <p class="mt-5 text-[15px] leading-[1.6] text-[color:var(--color-ink-300)] max-w-[620px]">
        Not a recording. Scripted boot-up, then the prompt unlocks — type any
        <span class="mono text-[color:var(--color-ink-100)]">stack</span> command (try
        <span class="mono text-[color:var(--color-ink-100)]">stack recommend "b2b saas with auth"</span>
        or <span class="mono text-[color:var(--color-ink-100)]">stack add supabase posthog</span>)
        and see the real output the CLI would print, driven by the same provider catalog
        the binary ships with.
      </p>
    </header>

    <StackREPL client:visible />
  </section>

  <ProvidersGrid />

  <HowItWorks />

  <UseCasesSection />

  <Templates />

  <!-- § 07 · Claude Code — the agent runs Stack -->
  <section id="claude-code" class="relative mx-auto max-w-[1240px] px-6 sm:px-10 pt-20 sm:pt-24 pb-20 sm:pb-24">
    <div class="section-rule mb-10"><span>§ 07 · Agent-native</span></div>

    <div class="grid grid-cols-1 lg:grid-cols-[0.85fr_1fr] gap-10 lg:gap-14 items-start">
      <div class="lg:pt-2 lg:sticky lg:top-20" data-reveal>
        <div class="chip mb-5">
          <span class="chip-dot"></span>
          MCP · Claude Code plugin
        </div>

        <h2 class="display text-[color:var(--color-ink-50)]" style="font-size: clamp(32px, 4.2vw, 52px);">
          Your agent can <span class="display-accent">run Stack</span> directly.
        </h2>

        <p class="mt-5 text-[15px] leading-[1.6] text-[color:var(--color-ink-300)]">
          Stack ships as an MCP server + a first-party Claude Code plugin. From chat,
          call <code class="mono text-[color:var(--color-ink-100)]">/stack:add</code> and Claude
          provisions the upstream resource, stores every secret in Phantom, and re-wires
          <code class="mono text-[color:var(--color-ink-100)]">.mcp.json</code> — zero copy-paste.
        </p>

        <ul class="mt-8 space-y-4 text-sm">
          {[
            { t: "MCP-native", d: "Every CLI command is exposed as an MCP tool." },
            { t: "Plugin commands", d: "/stack:add · /stack:doctor · /stack:open live in chat." },
            { t: "Phantom-gated", d: "The agent sees a slot name, never a key." },
          ].map((row) => (
            <li class="flex items-start gap-3">
              <span class="mt-1 w-2 h-2 bg-[color:var(--color-blade-500)] shrink-0"></span>
              <div>
                <div class="text-[color:var(--color-ink-50)] mono text-[13px]">{row.t}</div>
                <div class="text-[color:var(--color-ink-400)] mt-0.5">{row.d}</div>
              </div>
            </li>
          ))}
        </ul>

        <div class="mt-8 panel-steel p-4 mono text-[12px]" style="border-left: 2px solid var(--color-blade-500);">
          <div class="ansi-dim mb-1"># one-time setup — in any Claude Code session</div>
          <div><span class="ansi-blade select-none">›</span> <span class="ansi-white">/plugin marketplace add ashlrai/ashlr-stack</span></div>
          <div><span class="ansi-blade select-none">›</span> <span class="ansi-white">/plugin install stack@ashlr</span></div>
        </div>
      </div>

      <div data-reveal>
        <ClaudeCodeDemo client:visible />
      </div>
    </div>
  </section>

  <McpClients />
  <Constellation />
  <FAQSection />
  <Footer />
</Base>
