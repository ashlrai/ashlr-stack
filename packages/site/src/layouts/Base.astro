---
import "~/styles/global.css";
import SmoothScroll from "~/components/SmoothScroll";
import StickyInstall from "~/components/StickyInstall";
import {
  DEFAULT_DESCRIPTION,
  DEFAULT_TITLE,
  SITE_NAME,
  SITE_URL,
  buildOgMeta,
} from "~/lib/og";
import {
  breadcrumbSchema,
  homepageSchemas,
  type BreadcrumbItem,
} from "~/lib/structured-data";

export interface Props {
  title?: string;
  description?: string;
  /** Full URL. Defaults to the current page URL built from Astro.site. */
  canonical?: string;
  /** Override the OG image (absolute or site-root-relative). */
  ogImage?: string;
  /** og:type. "website" for marketing, "article" for blog posts. */
  ogType?: "website" | "article" | "profile";
  /** Set to true on /docs pages, etc. Defaults to follow,index. */
  noindex?: boolean;
  /** Breadcrumb trail for JSON-LD. Omit on the homepage. */
  breadcrumbs?: BreadcrumbItem[];
  /**
   * By default the homepage emits Organization + WebSite + SoftwareApplication
   * schemas. Sub-pages set this to false to skip the SoftwareApplication entry.
   */
  homepageSchema?: boolean;
  /**
   * Additional JSON-LD schema objects to emit alongside the defaults. Used by
   * docs pages to attach TechArticle / HowTo / FAQPage / ItemList data.
   */
  extraSchemas?: Record<string, unknown>[];
  /** rel="prev" pagination link (absolute or site-root-relative). */
  prevLink?: string;
  /** rel="next" pagination link (absolute or site-root-relative). */
  nextLink?: string;
}

const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESCRIPTION,
  canonical: canonicalProp,
  ogImage,
  ogType = "website",
  noindex = false,
  breadcrumbs,
  homepageSchema = true,
  extraSchemas,
  prevLink,
  nextLink,
} = Astro.props;

const canonical =
  canonicalProp ??
  new URL(Astro.url.pathname, Astro.site ?? SITE_URL).toString();

const ogMeta = buildOgMeta({
  title,
  description,
  canonical,
  ogImage,
  ogType,
});

const robots = noindex ? "noindex,nofollow" : "index,follow";

const schemas: Record<string, unknown>[] = [];
if (homepageSchema) {
  schemas.push(...homepageSchemas());
}
if (breadcrumbs && breadcrumbs.length > 0) {
  schemas.push(breadcrumbSchema(breadcrumbs));
}
if (extraSchemas && extraSchemas.length > 0) {
  schemas.push(...extraSchemas);
}

function toAbsoluteLink(pathOrUrl: string): string {
  if (/^https?:\/\//i.test(pathOrUrl)) return pathOrUrl;
  const base = (Astro.site ?? new URL(SITE_URL + "/")).toString().replace(/\/$/, "");
  if (pathOrUrl.startsWith("/")) return base + pathOrUrl;
  return `${base}/${pathOrUrl}`;
}

const absolutePrev = prevLink ? toAbsoluteLink(prevLink) : undefined;
const absoluteNext = nextLink ? toAbsoluteLink(nextLink) : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Referrer policy — preserves referrer for same-origin + HTTPS → HTTPS
         so Vercel Web Analytics + provider attribution work correctly. -->
    <meta name="referrer" content="no-referrer-when-downgrade" />

    <!-- Color scheme + theme -->
    <meta name="color-scheme" content="dark light" />
    <meta
      name="theme-color"
      content="#e96b2a"
      media="(prefers-color-scheme: dark)"
    />
    <meta
      name="theme-color"
      content="#0b0b0d"
      media="(prefers-color-scheme: light)"
    />

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/svg+xml" sizes="32x32" href="/favicon-32.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.svg" />
    <link rel="mask-icon" href="/favicon.svg" color="#e96b2a" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- Canonical + robots -->
    <link rel="canonical" href={canonical} />
    <meta name="robots" content={robots} />
    <meta name="googlebot" content={robots} />

    <!-- Pagination hints (rel=prev/next) — used by AI crawlers + classic SEO. -->
    {absolutePrev && <link rel="prev" href={absolutePrev} />}
    {absoluteNext && <link rel="next" href={absoluteNext} />}

    <!-- Title + description -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Ashlr" />
    <meta name="generator" content={Astro.generator} />

    <!-- OG + Twitter — generated from ~/lib/og.ts -->
    {
      ogMeta.map((tag) =>
        tag.attr === "property" ? (
          <meta property={tag.key} content={tag.value} />
        ) : (
          <meta name={tag.key} content={tag.value} />
        ),
      )
    }

    <!-- RSS — served by src/pages/feed.xml.ts -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE_NAME} — RSS`}
      href="/feed.xml"
    />

    <!-- Sitemap (emitted by @astrojs/sitemap) -->
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    <!-- Self-hosted fonts — PP Monument Grotesk + Berkeley Mono. Dropped in
         at public/fonts/{monument,berkeley}/. If the files are absent,
         @font-face silently falls back to system fonts. -->
    <link
      rel="preload"
      as="font"
      href="/fonts/monument/PPMonumentGrotesk-Variable.woff2"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      as="font"
      href="/fonts/berkeley/BerkeleyMono-Regular.woff2"
      type="font/woff2"
      crossorigin
    />

    <!-- JSON-LD structured data -->
    {
      schemas.map((schema) => (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(schema)}
        />
      ))
    }

    <slot name="head" />
  </head>
  <body class="antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:bg-[color:var(--color-blade-500)] focus:text-[color:var(--color-ink-950)] focus:px-3 focus:py-2 focus:text-sm"
    >
      Skip to content
    </a>

    <!-- Lenis smooth scroll + GSAP ScrollTrigger registration. One mount. -->
    <SmoothScroll client:load />

    <!-- Persistent install bar — slides in after the hero scrolls out. -->
    <StickyInstall client:idle />

    <main id="main">
      <slot />
    </main>

    <!-- Vercel Web Analytics — ships regardless of plan; no-ops until the
         dashboard feature flag is on. Deferred so it never blocks paint. -->
    <script is:inline defer src="/_vercel/insights/script.js"></script>
  </body>
</html>
