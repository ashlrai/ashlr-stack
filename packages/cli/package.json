{
  "name": "@ashlr/stack",
  "version": "0.2.0",
  "description": "Ashlr Stack CLI — the control plane for your entire dev stack. One command to provision, wire, and operate every third-party service in your project. 29 providers, MCP-native.",
  "license": "MIT",
  "author": {
    "name": "Mason Wyatt",
    "url": "https://github.com/ashlrai"
  },
  "homepage": "https://stack.ashlr.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ashlrai/ashlr-stack.git",
    "directory": "packages/cli"
  },
  "bugs": "https://github.com/ashlrai/ashlr-stack/issues",
  "keywords": [
    "ashlr",
    "stack",
    "cli",
    "mcp",
    "claude-code",
    "phantom-secrets",
    "supabase",
    "neon",
    "vercel",
    "cloudflare",
    "openai",
    "anthropic",
    "provisioning",
    "devops",
    "control-plane"
  ],
  "type": "module",
  "bin": {
    "stack": "./dist/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm && node -e \"const fs=require('fs');const f='dist/index.js';let c=fs.readFileSync(f,'utf8');if(c.startsWith('#!'))c=c.slice(c.indexOf('\\n')+1);fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c);fs.chmodSync(f,0o755)\"",
    "prepublishOnly": "bun run build",
    "dev": "bun run src/index.ts",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@ashlr/stack-core": "workspace:*",
    "@clack/prompts": "^0.8.2",
    "citty": "^0.1.6",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
